# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# ============================================================

# --- Kaggle (only needed if downloading the dataset via CLI) ---
COHERE_API_KEY=your_cohere_api_key

# --- PostgreSQL: admin connection (ETL pipeline) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/olist_ecommerce

# --- PostgreSQL: read-only connection (OpenClaw agent) ---
# Uses the olist_reader role created by sql/create_readonly_user.sql
READONLY_DB_URL=postgresql://olist_reader:change_me_before_use@localhost:5432/olist_ecommerce

# --- Anthropic (Claude LLM for OpenClaw) ---
GROQ_API_KEY=gsk_...

# --- Telegram Bot ---
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Get your user ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_ID=your_telegram_numeric_user_id

# --- Python path for chart generation (OpenClaw calls this) ---
# Use the full path to the venv python on Windows:
PYTHON_PATH=C:\Users\...\.venv\Scripts\python.exe
